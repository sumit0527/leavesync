# =============================================
# LeaveSync — Environment Variables Template
# Copy this file to .env and fill in values
# =============================================

# Supabase (required)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service key — used only in scripts/edge functions, NEVER expose to browser
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App identifier (set by platform automatically)
VITE_APP_ID=app-xxxxxxxxxxxxxxxx
